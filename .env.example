# FUSE — environment variables
# The demo runs fully on mock data. Add these to switch on live integrations.

# Helius — wallet balances (getAssetsByOwner)
NEXT_PUBLIC_HELIUS_API_KEY=

# Jupiter — swap routing / quotes / prices (proxied server-side)
# Free tier: https://lite-api.jup.ag  ·  Paid tier: https://api.jup.ag (set JUPITER_API_KEY)
JUPITER_API=https://lite-api.jup.ag
JUPITER_API_KEY=

# Pyth — price feeds
NEXT_PUBLIC_PYTH_ENDPOINT=https://hermes.pyth.network

# Solana mainnet RPC — used for balances, prices, and settlement.
# The public endpoint rate-limits hard; use a Helius/QuickNode URL for reliability.
NEXT_PUBLIC_SOLANA_RPC=https://solana-rpc.publicnode.com

# Novus.ai — product analytics. No key needed here: the Novus GitHub
# integration injects it automatically (globalThis.__novus__ at runtime).

# Note: the recipient (who receives the USDC) is entered by the payer at
# checkout — there is no merchant address to configure here.
